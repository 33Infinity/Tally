<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ScanSale.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ScanSale.Views"
    FlyoutBehavior="Disabled"
    Title="Tally">

    <!-- Initial route: login (no tabs). On success the VM navigates to //main. -->
    <ShellContent
        Route="login"
        ContentTemplate="{DataTemplate views:LoginPage}" />

    <ShellContent
        Route="paywall"
        ContentTemplate="{DataTemplate views:PaywallPage}" />

    <TabBar Route="main">
        <Tab Title="Items">
            <ShellContent ContentTemplate="{DataTemplate views:ItemsPage}" />
        </Tab>
        <Tab Title="New Sale">
            <ShellContent ContentTemplate="{DataTemplate views:NewSalePage}" />
        </Tab>
        <Tab Title="History">
            <ShellContent ContentTemplate="{DataTemplate views:SalesHistoryPage}" />
        </Tab>
    </TabBar>

</Shell>
