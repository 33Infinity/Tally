<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ScanSale.ViewModels"
             xmlns:m="clr-namespace:ScanSale.Models"
             x:Class="ScanSale.Views.SalesHistoryPage"
             x:DataType="vm:SalesHistoryViewModel"
             Title="Sales History">
    <Grid RowDefinitions="*,Auto">
        <CollectionView Grid.Row="0" ItemsSource="{Binding Sales}" SelectionMode="None" Margin="8">
            <CollectionView.EmptyView>
                <Label Text="No sales yet." HorizontalOptions="Center" VerticalOptions="Center" TextColor="Gray" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="m:Sale">
                    <Border Margin="4" Padding="12" StrokeShape="RoundRectangle 10" Stroke="#22000000">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SalesHistoryViewModel}}, Path=OpenCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="{Binding CreatedLocal, StringFormat='{0:g}'}" FontAttributes="Bold" />
                                <Label Text="{Binding ItemCount, StringFormat='{0} item(s)'}" FontSize="13" TextColor="Gray" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="{Binding Total, StringFormat='{0:C}'}" FontAttributes="Bold" FontSize="16" VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Padding="16,10" BackgroundColor="#11000000">
            <Label Grid.Column="0" Text="All-time total" FontAttributes="Bold" VerticalOptions="Center" />
            <Label Grid.Column="1" Text="{Binding GrandTotal, StringFormat='{0:C}'}" FontAttributes="Bold" FontSize="16" />
        </Grid>
    </Grid>
</ContentPage>
