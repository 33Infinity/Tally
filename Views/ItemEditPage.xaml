<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ScanSale.ViewModels"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
             x:Class="ScanSale.Views.ItemEditPage"
             x:DataType="vm:ItemEditViewModel"
             Title="{Binding Title}">
    <ScrollView>
        <VerticalStackLayout Spacing="12" Padding="20" MaximumWidthRequest="520" HorizontalOptions="Center">

            <Label Text="Item ID" FontAttributes="Bold" />
            <Label Text="Scan the item's QR/barcode — it becomes the item id and is matched at sale time."
                   FontSize="12" TextColor="Gray" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry Grid.Column="0" Text="{Binding Code}" Placeholder="scan to fill (or type)" />
                <Button Grid.Column="1" Text="{Binding IsScanning, Converter={StaticResource ScanButtonText}}"
                        Command="{Binding ToggleScanCommand}" />
            </Grid>
            <Border x:Name="ScannerHost" IsVisible="{Binding IsScanning}" HeightRequest="220"
                    StrokeShape="RoundRectangle 10" Stroke="#22000000" />
            <Label Text="{Binding Status}" FontSize="13" TextColor="#1565C0"
                   IsVisible="{Binding Status, Converter={StaticResource IsStringNotEmpty}}" />

            <Label Text="Price" FontAttributes="Bold" Margin="0,8,0,0" />
            <Entry Text="{Binding PriceText}" Placeholder="0.00" Keyboard="Numeric" />

            <Label Text="Tax rate (%)" FontAttributes="Bold" />
            <Entry Text="{Binding TaxText}" Placeholder="e.g. 8.25 (optional)" Keyboard="Numeric" />

            <Label Text="Description (optional)" FontAttributes="Bold" />
            <Entry Text="{Binding Description}" Placeholder="e.g. Large Coffee" />

            <Label Text="{Binding Error}" TextColor="#D32F2F"
                   IsVisible="{Binding Error, Converter={StaticResource IsStringNotEmpty}}" Margin="0,4,0,0" />

            <Button Text="Save" Command="{Binding SaveCommand}" Margin="0,8,0,0" />
            <Button Text="Delete" Command="{Binding DeleteCommand}" IsVisible="{Binding CanDelete}" BackgroundColor="#D32F2F" />
            <Button Text="Cancel" Command="{Binding CancelCommand}" BackgroundColor="Transparent" TextColor="Gray" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
